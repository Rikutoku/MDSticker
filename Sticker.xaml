<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MDSticker.Sticker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MDSticker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:a="using:Microsoft.UI.Xaml.Media.Animation"
    mc:Ignorable="d"
    Title="Sticker">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
        <!--<Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="Open New" Click="AddButton_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="OpenFile"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Grid.ContextFlyout>-->

        <ScrollViewer Padding="16,8,16,16" VerticalScrollBarVisibility="Auto">
            <controls:MarkdownTextBlock
                x:Name="MarkdownViewer"
                Text="Select a file to begin..."
                Background="Transparent" />
        </ScrollViewer>

        <Grid x:Name="customTitlebar"
              VerticalAlignment="Top"
              Height="40"
              Background="Transparent"
              PointerEntered="customTitlebar_PointerEntered"
              PointerExited="customTitlebar_PointerExited">
            <Grid
                x:Name="customTitlebarContent"
                Background="{StaticResource SystemAccentColor}"
                Translation="0,-32,0">

                <Grid.TranslationTransition>
                    <Vector3Transition/>
                </Grid.TranslationTransition>

                <Button x:Name="OpenSticker"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SubtleButtonStyle}"
                        Click="OpenSticker_Click">

                    <StackPanel Orientation="Horizontal">
                        <SymbolIcon Symbol="OpenFile" />
                    </StackPanel>
                </Button>

                <Button x:Name="CloseSticker"
                        HorizontalAlignment="Right"
                        Style="{StaticResource SubtleButtonStyle}"
                        Click="CloseSticker_Click">

                    <StackPanel Orientation="Horizontal">
                        <SymbolIcon Symbol="Cancel" />
                    </StackPanel>
                </Button>
                
            </Grid>
        </Grid>
    </Grid>
</Window>